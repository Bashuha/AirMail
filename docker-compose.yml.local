services:
  notify:
    build: .
    container_name: notify
    extra_hosts:
      - "host.docker.internal:host-gateway"
    environment:
      - RMQ_HOST=host.docker.internal
      - RMQ_PORT=5672
      - RMQ_USER
      - RMQ_PASSWORD
      - SMTP_USER
      - SMTP_PASSWORD
      - SMTP_FROM
      - ZABBIX_URL
    volumes:
      - notify_sqlite_data:/app/data
      - ./logs:/app/logs
    restart: unless-stopped
volumes:
  notify_sqlite_data: